# Falls Origin - Production .htaccess
RewriteEngine On

# 1. Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Support Clean URLs for Products
# Target: fallscoffee.ca/product/yirgacheffe -> product.php?slug=yirgacheffe
RewriteRule ^product/([a-zA-Z0-9-]+)/?$ product.php?slug=$1 [L,QSA]

# 3. Support Clean URLs for Tracking
# Target: fallscoffee.ca/track/ORD-123 -> track-order.php?token=ORD-123
RewriteRule ^track/([a-zA-Z0-9-]+)/?$ track-order.php?token=$1 [L,QSA]

# 4. Remove .php extension (Optional but recommended)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# 5. Security: Disable Directory Browsing
Options -Indexes

# 6. Optimized Caching for Assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
</IfModule>
