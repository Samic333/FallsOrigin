{
    "name": "falls-origin-coffee-server",
    "version": "1.0.0",
    "description": "Backend server for Falls Origin Coffee e-commerce",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "migrate": "node dist/scripts/migrate.js",
        "test": "jest",
        "test:integration": "jest --testPathPattern=integration",
        "lint": "eslint src --ext .ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "express": "^4.18.2",
        "pg": "^8.11.3",
        "stripe": "^14.10.0",
        "nodemailer": "^6.9.7",
        "bcrypt": "^5.1.1",
        "jsonwebtoken": "^9.0.2",
        "express-validator": "^7.0.1",
        "helmet": "^7.1.0",
        "cors": "^2.8.5",
        "express-rate-limit": "^7.1.5",
        "dotenv": "^16.3.1",
        "node-geocoder": "^4.3.0",
        "winston": "^3.11.0",
        "compression": "^1.7.4",
        "multer": "^1.4.5-lts.1"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.6",
        "@types/pg": "^8.10.9",
        "@types/nodemailer": "^6.4.14",
        "@types/bcrypt": "^5.0.2",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/cors": "^2.8.17",
        "@types/compression": "^1.7.5",
        "@types/multer": "^1.4.11",
        "typescript": "^5.3.3",
        "tsx": "^4.7.0",
        "@typescript-eslint/eslint-plugin": "^6.17.0",
        "@typescript-eslint/parser": "^6.17.0",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "@types/jest": "^29.5.11"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}