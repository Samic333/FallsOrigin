# Server Configuration
NODE_ENV=development
PORT=8080

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/falls_coffee

# Stripe
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# Email Provider (choose one)
# Option 1: SendGrid
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.YOUR_KEY_HERE
EMAIL_FROM=orders@fallsorigincoffee.com
EMAIL_FROM_NAME=Falls Origin Coffee

# Option 2: Mailgun
# EMAIL_PROVIDER=mailgun
# MAILGUN_API_KEY=YOUR_KEY_HERE
# MAILGUN_DOMAIN=mg.fallsorigincoffee.com
# EMAIL_FROM=orders@fallsorigincoffee.com
# EMAIL_FROM_NAME=Falls Origin Coffee

# Option 3: AWS SES
# EMAIL_PROVIDER=ses
# AWS_ACCESS_KEY_ID=YOUR_KEY_HERE
# AWS_SECRET_ACCESS_KEY=YOUR_SECRET_HERE
# AWS_REGION=us-east-1
# EMAIL_FROM=orders@fallsorigincoffee.com
# EMAIL_FROM_NAME=Falls Origin Coffee

# Admin Configuration
ADMIN_EMAIL=admin@fallsorigincoffee.com
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# Admin Password (hashed with bcrypt)
# Generate with: node -e "console.log(require('bcrypt').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=$2b$10$PLACEHOLDER_HASH_REPLACE_THIS

# Delivery Configuration
BASE_CITY=Toronto, ON, Canada
BASE_LATITUDE=43.6532
BASE_LONGITUDE=-79.3832
DELIVERY_RADIUS_KM=200

# Geocoding API (for distance calculation)
# Option 1: Google Maps
GEOCODING_PROVIDER=google
GOOGLE_MAPS_API_KEY=YOUR_KEY_HERE

# Option 2: OpenCage (free tier available)
# GEOCODING_PROVIDER=opencage
# OPENCAGE_API_KEY=YOUR_KEY_HERE

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Review Scheduler
REVIEW_EMAIL_DELAY_HOURS=48

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
